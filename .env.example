# Required
PURVIEW_ACCOUNT_NAME=my-purview-account

# Optional: Service Principal (Production / CI)
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret

# Optional: Inbound authentication (required for production / M365 Copilot)
# Set both variables to enable Entra ID Bearer token validation on all requests.
# ENTRA_AUDIENCE is the Application ID URI of the server app registration.
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ENTRA_AUDIENCE=api://<your-server-app-client-id>

# Optional: Server configuration
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
# Per-client (IP) request limit; set to 0 to disable rate limiting
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT_SECONDS=30

# Optional: OpenTelemetry
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- ETL / PostgreSQL-backed serving ---
# When SERVING_BACKEND=postgres, MCP tools read from a local Postgres database
# that a built-in ETL keeps in sync with Purview. This avoids hitting Purview's
# API rate limit on every agent request. Set SERVING_BACKEND=purview to bypass
# the database and serve live from the Purview API (rollback / no-DB mode).
SERVING_BACKEND=postgres
# Async SQLAlchemy connection URL (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://purview:purview@postgres:5432/purview
# Background ETL scheduler
ETL_ENABLED=true
ETL_INTERVAL_SECONDS=900
# Every Nth scheduled run is a full reconcile (detects deletes); others are incremental.
ETL_FULL_RECONCILE_EVERY_N_RUNS=24
ETL_CONCURRENCY=6
ETL_BATCH_SIZE=500
ETL_LINEAGE_DEPTH=3
